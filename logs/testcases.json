    {
      "id": "b7a2f409-f805-4eaa-b65b-3297c28d4633",
      "name": "222",
      "priority": "P1",
      "description": "通过 Playwright 录制自动创建",
      "script": "import re\nfrom playwright.sync_api import Playwright, sync_playwright, expect\n\n\ndef run(playwright: Playwright) -> None:\n    browser = playwright.chromium.launch(headless=False)\n    context = browser.new_context(viewport={\"width\":1280,\"height\":720})\n    page = context.new_page()\n    page.goto(\"https://dsep-portal-test.minmetals.com.cn/portal/signin\")\n    page.get_by_placeholder(\"输入账号\").click()\n    page.get_by_placeholder(\"输入账号\").fill(\"zhangbaohua\")\n    page.get_by_placeholder(\"输入账号\").press(\"Tab\")\n    page.get_by_placeholder(\"输入密码\").click(button=\"right\")\n    page.get_by_placeholder(\"输入密码\").fill(\"3657801987Aa!\")\n    with page.expect_popup() as page1_info:\n        page.locator(\"div\").filter(has_text=re.compile(r\"^我已阅读并同意《服务协议》 及 《隐私政策》$\")).nth(2).click()\n    page1 = page1_info.value\n    page1.close()\n    page.locator(\".el-checkbox__inner\").first.click()\n    page.get_by_role(\"button\", name=\"登录\").click()\n\n    # ---------------------\n    context.close()\n    browser.close()\n\n\nwith sync_playwright() as playwright:\n    run(playwright)\n",
